pipeline {
    agent any

    stages {

        stage('PULL') {
            steps {
                git branch: 'dev', url: 'https://github.com/amitsingh3363/Easycrud-student-registration.git'
            }
        }

        stage('FRONTEND-DOCKER-BUILD') {
            steps {
                sh '''
                cd frontend
                docker build -f dockerfile -t amitsingh3363/cicd-pipeline:auto-frontend .
                '''
            }
        }

        stage('BACKEND-DOCKER-BUILD') {
            steps {
                sh '''
                cd backend
                docker build -f dockerfile -t amitsingh3363/cicd-pipeline:auto-backend .
                '''
            }
        }

        stage('DOCKER-PUSH') {
            steps {
                sh '''
                docker push amitsingh3363/cicd-pipeline:auto-frontend
                docker push amitsingh3363/cicd-pipeline:auto-backend
                '''
            }
        }

        stage('DOCKER-CLEAN') {
            steps {
                sh '''
                docker rmi -f amitsingh3363/cicd-pipeline:auto-frontend
                docker rmi -f amitsingh3363/cicd-pipeline:auto-backend
                '''
            }
        }

        stage('DEPLOY') {
            steps {
                sh 'kubectl apply -f simple-deploy/'
            }
        }

    }
}
